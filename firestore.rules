rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /users/{userId}/devices/{deviceId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /responders/{responderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /sos_events/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /emergency_requests/{requestId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /responder_verification_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /chats/{chatId} {
      // Allow any signed in user to read and update chats for now
      // This is the functional "Loosened" state that works for the hackathon
      allow read, update: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn()
        && resource.data.status == 'cancelled'
        && resource.data.participantUids.hasAny([request.auth.uid]);

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if isSignedIn()
          && get(/databases/$(database)/documents/chats/$(chatId)).data.status == 'cancelled'
          && get(/databases/$(database)/documents/chats/$(chatId)).data.participantUids.hasAny([request.auth.uid]);
      }
    }

    match /responder_reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
  }
}
